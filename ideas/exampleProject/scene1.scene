<?xml version="1.0"?>
<game>
    <gameSettings>
        <setting name="sceneName" value="scene1"></setting>
    </gameSettings>
    <!--
        wanna add 2 types of ways to load scripts from a script object
        path = load script from the script folder
        abs_path = load script from absolute path (key /base/ will be base of project)
        engine will default to using path
    -->
    <script name="testLua" path="test.lua"></script>
    <object type="box" name="box" x="50" y="50" w="50" h="50" zIndex="5" hexRbg="#FF0000" transparency="1"></object>
    <object type="sprite" name="superCoolSprite" x="200" y="50" w="50" h="50" path="testImg.png" transparency="1"></object>
    <object type="triangle" name="triangle" x="50" y="50" w="50" h="50" zIndex="10" hexRbg="#00FF00" transparency="1"></object>
    <object type="circle" name="circle" x="-200" y="50" r="25" hexRbg="#0000FF" transparency="1"></object>
    <object type="text" name="text" x="0" y="150" w="200" h="50" textStr="Hello, Neptune!" textHexRbg="#FFFF00" textTransparency="1" hexRbg="#000000" transparency="1"></object>
    <listener name="listener"></listener>
    <audio name="audio" path="test.wav" isLooping="true"></audio>
</game>