<?xml version="1.0"?>
<game>
    <gameSettings>
        <setting name="sceneName" value="scene1"></setting>
    </gameSettings>
    <!--
        wanna add 2 types of ways to load scripts from a script object
        path = load script from the script folder
        abs_path = load script from absolute path (key /base/ will be base of project)
        engine will default to using path
    -->
    <script name="testLua" path="test.lua"></script>
    <object type="box" name="box" x="50" y="50" w="50" h="50" hexRbg="#FF0000" transparency="1"></object>
    <object type="sprite" name="sprite" x="200" y="50" w="50" h="50" path="testImg.png" transparency="1"></object>
</game>